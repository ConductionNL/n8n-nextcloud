<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
    <id>n8n</id>
    <name>n8n</name>
    <summary>n8n workflow automation for Nextcloud</summary>
    <description><![CDATA[n8n Workflow Automation for Nextcloud

Integrate n8n workflow automation with your Nextcloud instance.

- Build workflows with 400+ integrations
- Automate tasks directly from Nextcloud
- Visual workflow editor
- Free and open source

This is an ExApp (External Application) - Nextcloud will automatically manage the n8n container.
    ]]></description>
    <version>1.0.0</version>
    <licence>EUPL-1.2</licence>
    <author mail="info@conduction.nl" homepage="https://www.conduction.nl/">Conduction</author>
    <category>tools</category>
    <category>integration</category>
    <website>https://github.com/ConductionNL/openregister</website>
    <bugs>https://github.com/ConductionNL/openregister/issues</bugs>
    <repository>https://github.com/ConductionNL/openregister</repository>

    <dependencies>
        <nextcloud min-version="30" max-version="33"/>
    </dependencies>

    <external-app>
        <docker-install>
            <registry>ghcr.io</registry>
            <image>conductionnl/n8n-nextcloud</image>
            <image-tag>latest</image-tag>
        </docker-install>

        <routes>
            <route>
                <url>.*</url>
                <verb>GET,POST,PUT,DELETE,PATCH,OPTIONS</verb>
                <access_level>ADMIN</access_level>
                <headers_to_exclude>[]</headers_to_exclude>
            </route>
        </routes>

        <environment-variables>
            <variable>
                <name>N8N_EXTERNAL_DATABASE</name>
                <display-name>Database URL</display-name>
                <description>PostgreSQL connection string (e.g., postgres://user:pass@host:5432/n8n). Leave empty for SQLite.</description>
            </variable>
            <variable>
                <name>N8N_ENCRYPTION_KEY</name>
                <display-name>Encryption Key</display-name>
                <description>Encryption key for stored credentials. Auto-generated if empty.</description>
            </variable>
            <variable>
                <name>N8N_TIMEZONE</name>
                <display-name>Timezone</display-name>
                <description>Timezone for workflow schedules (default: Europe/Amsterdam)</description>
            </variable>
        </environment-variables>
    </external-app>
</info>
